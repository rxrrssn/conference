---
import Social from "../ui/Social.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const [staticData] = await getCollection("staticData");
const {
  alias,
  email,
  linkedin,
  emailIconName,
  linkedinIconName,
} = staticData.data;
---

<footer
  class="relative bottom-0 w-full px-4 py-8 font-medium text-blacktext dark:bg-transparent dark:border-b-2 dark:border-zinc-800 dark:text-zinc-300 max-lg:mt-3"
  role="contentinfo"
  aria-label="Site footer"
>
  <nav
    class="mx-auto flex max-w-7xl flex-row items-center justify-between gap-4 text-xl max-xl:px-6 max-sm:flex-col"
    aria-label="Footer navigation"
  >
<div class="flex items-center">

  <!-- LOGO 1 -->
  <div
    class="relative h-3  align-middle cursor-pointer pr-4 before:absolute before:left-1/2 before:top-1/2 before:h-full before:w-[10%] before:-translate-x-1/2 before:-translate-y-1/2 before:rounded-full before:bg-[#50fd8f25] before:blur-3xl before:opacity-80 before:-z-1 hover:text-mint-500 transition-all [text-shadow:0_1px_2px_#000]"
  >
    <a href="/" aria-label="Return to homepage">
      <Icon class="h-3 w-auto align-middle dark:text-white text-blacktext" name="purple" />
    </a>
  </div>

  <!-- GREEN DIVIDER -->
  <div class="h-3 w-[2px] bg-riptide-300 rounded-full align-middle"></div>

  <!-- LOGO 2 -->
  <div class="relative h-3 cursor-pointer pl-4 hover:text-mint-500 transition-all [text-shadow:0_1px_2px_#000]">
    <a href="/" aria-label="Return to homepage">
      <Icon class="h-3 w-auto align-middle dark:text-white text-blacktext" name="ellucian" />
    </a>
  </div>

</div>
    <div class="text-center">
      <a
        href={""}
        class="flex items-center justify-center gap-3 text-base font-normal italic max-sm:text-sm"
        aria-label="About the website development"
        >© 2026 <strong
          >Travis Hornbuckle.</strong
        > All rights reserved.</a> 
    </div>
    <div
      class="flex items-center justify-center gap-5"
      role="group"
      aria-label="Social media links"
    >
          <Social
        link={linkedin}
        iconName={linkedinIconName}
        label={`Visit ${alias} on LinkedIn`}
      />
      <Social
        link={`mailto:${email}`}
        iconName={emailIconName}
        label={`Send email to ${email}`}
      />

    </div>
  </nav>
</footer>
